void RefreshBoxes()
{
   CleanOldPPP();
   if(PositionsTotal()==0) { DeleteAll(); return; }

   for(int i=0;i<PositionsTotal();i++)
   {
      ulong ticket=PositionGetTicket(i);
      if(ticket==0) continue;
      if(PositionGetString(POSITION_SYMBOL)!=_Symbol) continue;

      long   pType  = PositionGetInteger(POSITION_TYPE);
      double entry  = PositionGetDouble(POSITION_PRICE_OPEN);
      double tp     = PositionGetDouble(POSITION_TP);
      double sl     = PositionGetDouble(POSITION_SL);
      double profit = PositionGetDouble(POSITION_PROFIT); 
      double lot    = PositionGetDouble(POSITION_VOLUME);
      double bid    = SymbolInfoDouble(_Symbol,SYMBOL_BID);
      double ask    = SymbolInfoDouble(_Symbol,SYMBOL_ASK);
      double live   = (pType==POSITION_TYPE_BUY)?bid:ask;

      ENUM_ORDER_TYPE ot  = (pType==POSITION_TYPE_BUY)?ORDER_TYPE_BUY:ORDER_TYPE_SELL;
      bool   isBuy        = (pType==POSITION_TYPE_BUY);
      string sfx          = IntegerToString((int)ticket);
      color  lCol         = isBuy?Color_Buy:Color_Sell;
      string side         = isBuy?"BUY":"SELL";
      string lotTxt       = DoubleToString(lot,2);

      color  pCol  = (profit>=0)?Color_Profit:Color_Loss;
      string pSign = (profit>=0)?"+":"-";
      string pTxt  = pSign+"$"+DoubleToString(MathAbs(profit),2);
      
      SetLine("E"+sfx, entry, lCol, Entry_LineWidth, false);
      SetLabel("E"+sfx, entry, side, lotTxt, pTxt, lCol, pCol, PREFIX+"BTN_E_"+sfx);

      double ppp = GetFrozenPPP(ticket,ot,entry,lot,live,profit);

      if(tp>0 && ppp!=0)
      {
         double tpM = FixedMoney(ppp,entry,tp,ot);
         SetLine("T"+sfx, tp, Color_TP, TP_LineWidth, TP_Dashed);
         SetLabel("T"+sfx, tp, "TP", lotTxt, "+$"+DoubleToString(MathAbs(tpM),2), Color_TP, Color_Profit, PREFIX+"BTN_T_"+sfx);
      }
      else
      {
         ObjectDelete(0,PREFIX+"LN_T"+sfx);
         ObjectDelete(0,PREFIX+"BX_T"+sfx+"_OUT"); ObjectDelete(0,PREFIX+"BX_T"+sfx+"_IN");
         ObjectDelete(0,PREFIX+"SD_T"+sfx); ObjectDelete(0,PREFIX+"S1_T"+sfx);
         ObjectDelete(0,PREFIX+"LT_T"+sfx); ObjectDelete(0,PREFIX+"S2_T"+sfx);
         ObjectDelete(0,PREFIX+"VL_T"+sfx);
         ObjectDelete(0,PREFIX+"BTN_T_"+sfx);
      }

      if(sl>0 && ppp!=0)
      {
         double slM = FixedMoney(ppp,entry,sl,ot);
         SetLine("S"+sfx, sl, Color_SL, SL_LineWidth, SL_Dashed);
         SetLabel("S"+sfx, sl, "SL", lotTxt, "-$"+DoubleToString(MathAbs(slM),2), Color_SL, Color_Loss, PREFIX+"BTN_S_"+sfx);
      }
      else
      {
         ObjectDelete(0,PREFIX+"LN_S"+sfx);
         ObjectDelete(0,PREFIX+"BX_S"+sfx+"_OUT"); ObjectDelete(0,PREFIX+"BX_S"+sfx+"_IN");
         ObjectDelete(0,PREFIX+"SD_S"+sfx); ObjectDelete(0,PREFIX+"S1_S"+sfx);
         ObjectDelete(0,PREFIX+"LT_S"+sfx); ObjectDelete(0,PREFIX+"S2_S"+sfx);
         ObjectDelete(0,PREFIX+"VL_S"+sfx);
         ObjectDelete(0,PREFIX+"BTN_S_"+sfx); 
      }
   }
   
   if(PositionsTotal() > 0)
   {
      for(int i=0;i<PositionsTotal();i++)
      {
         if(PositionGetTicket(i)==0) continue;
         if(PositionGetString(POSITION_SYMBOL)!=_Symbol) continue;
         SetEquityBox(PositionGetDouble(POSITION_PRICE_OPEN));
         break;
      }
   }
}

