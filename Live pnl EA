int OnInit()
{
   string oldPrefixes[] = {
      "TV19_","TV18_","TV17_","TV16_","TV15_","TV14_","TV13_","TV12_","TV11_","TV10_",
      "TVOP_","TVBOX_"
   };
   for(int p = 0; p < ArraySize(oldPrefixes); p++)
      ObjectsDeleteAll(0, oldPrefixes[p]);

   EventSetTimer(1); // Safely update chart exactly once per second
   
   trade.SetTypeFillingBySymbol(_Symbol); 
   trade.SetDeviationInPoints(100); 

   return INIT_SUCCEEDED;
}

void OnDeinit(const int reason)
{
   EventKillTimer(); DeleteAll();
   for(int i=GlobalVariablesTotal()-1;i>=0;i--)
   { string n=GlobalVariableName(i); if(StringFind(n,PPP_KEY)==0) GlobalVariableDel(n); }
}

void OnTimer() { RefreshBoxes(); }

// ── REMOVED OnTick() COMPLETELY TO PREVENT FREEZING ──

// ── Handle Chart Clicks with Audible Alerts ──
void OnChartEvent(const int id,const long &lp,const double &dp,const string &sp)
{ 
   if(id == CHARTEVENT_OBJECT_CLICK)
   {
      if(StringFind(sp, PREFIX + "BTN_") == 0)
      {
         ObjectSetInteger(0, sp, OBJPROP_STATE, false); 
         PlaySound("ok.wav"); 
         
         string actionStr = StringSubstr(sp, StringLen(PREFIX) + 4, 1); 
         ulong ticket = (ulong)StringToInteger(StringSubstr(sp, StringLen(PREFIX) + 6));

         if(actionStr == "E") // Close Entire Position
         {
            if(!trade.PositionClose(ticket))
               Alert("Broker rejected closing! Server Code: ", trade.ResultRetcode(), " | Local: ", GetLastError());
         }
         else if(actionStr == "T" || actionStr == "S") // Modify TP or SL
         {
            if(PositionSelectByTicket(ticket))
            {
               string sym = PositionGetString(POSITION_SYMBOL);
               int digits = (int)SymbolInfoInteger(sym, SYMBOL_DIGITS);

               double sl = PositionGetDouble(POSITION_SL);
               double tp = PositionGetDouble(POSITION_TP);

               if(actionStr == "T") tp = 0; 
               if(actionStr == "S") sl = 0; 

               if(sl > 0) sl = NormalizeDouble(sl, digits);
               if(tp > 0) tp = NormalizeDouble(tp, digits);

               if(!trade.PositionModify(ticket, sl, tp))
               {
                  uint serverCode = trade.ResultRetcode();
                  Alert("Broker rejected modify! Server Code: ", serverCode, " | Local: ", GetLastError());
               }
            }
         }
         
         RefreshBoxes();
         ChartRedraw();
      }
   }
}
