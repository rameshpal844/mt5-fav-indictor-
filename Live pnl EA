void SetLine(string id, double price, color col, int width, bool dashed)
{
   string n    = PREFIX+"LN_"+id;
   datetime t0 = iTime(_Symbol,_Period,0);
   int vis     = (int)ChartGetInteger(0,CHART_VISIBLE_BARS);
   datetime t1 = iTime(_Symbol,_Period,MathMin(LineExtendBars,vis>1?vis-1:1));
   if(ObjectFind(0,n)<0) ObjectCreate(0,n,OBJ_TREND,0,t1,price,t0,price);
   ObjectMove(0,n,0,t1,price); ObjectMove(0,n,1,t0,price);
   ObjectSetDouble(0,n,OBJPROP_PRICE,0,price);
   ObjectSetDouble(0,n,OBJPROP_PRICE,1,price);
   ObjectSetInteger(0,n,OBJPROP_COLOR,col);
   ObjectSetInteger(0,n,OBJPROP_WIDTH,width);
   ObjectSetInteger(0,n,OBJPROP_STYLE,dashed?STYLE_DASH:STYLE_SOLID);
   ObjectSetInteger(0,n,OBJPROP_RAY_RIGHT,false);
   ObjectSetInteger(0,n,OBJPROP_RAY_LEFT,false);
   ObjectSetInteger(0,n,OBJPROP_SELECTABLE,false);
   ObjectSetInteger(0,n,OBJPROP_BACK,true);
}

void SetRect(string name,int x,int y,int w,int h,color fill,color border,int t)
{
   string o=name+"_OUT",i=name+"_IN";
   if(ObjectFind(0,o)<0) ObjectCreate(0,o,OBJ_RECTANGLE_LABEL,0,0,0);
   ObjectSetInteger(0,o,OBJPROP_CORNER,CORNER_LEFT_UPPER);
   ObjectSetInteger(0,o,OBJPROP_XDISTANCE,x); ObjectSetInteger(0,o,OBJPROP_YDISTANCE,y);
   ObjectSetInteger(0,o,OBJPROP_XSIZE,w);     ObjectSetInteger(0,o,OBJPROP_YSIZE,h);
   ObjectSetInteger(0,o,OBJPROP_BGCOLOR,border);
   ObjectSetInteger(0,o,OBJPROP_BORDER_TYPE,BORDER_FLAT);
   ObjectSetInteger(0,o,OBJPROP_COLOR,border);
   ObjectSetInteger(0,o,OBJPROP_BACK,false);
   ObjectSetInteger(0,o,OBJPROP_SELECTABLE,false);
   if(ObjectFind(0,i)<0) ObjectCreate(0,i,OBJ_RECTANGLE_LABEL,0,0,0);
   ObjectSetInteger(0,i,OBJPROP_CORNER,CORNER_LEFT_UPPER);
   ObjectSetInteger(0,i,OBJPROP_XDISTANCE,x+t); ObjectSetInteger(0,i,OBJPROP_YDISTANCE,y+t);
   ObjectSetInteger(0,i,OBJPROP_XSIZE,w-t*2);   ObjectSetInteger(0,i,OBJPROP_YSIZE,h-t*2);
   ObjectSetInteger(0,i,OBJPROP_BGCOLOR,fill);
   ObjectSetInteger(0,i,OBJPROP_BORDER_TYPE,BORDER_FLAT);
   ObjectSetInteger(0,i,OBJPROP_COLOR,fill);
   ObjectSetInteger(0,i,OBJPROP_BACK,false);
   ObjectSetInteger(0,i,OBJPROP_SELECTABLE,false);
}

void SetText(string name,int x,int y,string txt,color col,int fs=-1)
{
   if(ObjectFind(0,name)<0) ObjectCreate(0,name,OBJ_LABEL,0,0,0);
   ObjectSetInteger(0,name,OBJPROP_CORNER,CORNER_LEFT_UPPER);
   ObjectSetInteger(0,name,OBJPROP_XDISTANCE,x);
   ObjectSetInteger(0,name,OBJPROP_YDISTANCE,y);
   ObjectSetInteger(0,name,OBJPROP_FONTSIZE,fs<0?FontSize:fs);
   ObjectSetString(0,name,OBJPROP_FONT,FontFace);
   ObjectSetInteger(0,name,OBJPROP_COLOR,col);
   ObjectSetString(0,name,OBJPROP_TEXT,txt);
   ObjectSetInteger(0,name,OBJPROP_SELECTABLE,false);
}

void SetXButton(string name, int x, int y, int size)
{
   if(ObjectFind(0, name) < 0) 
   {
      ObjectCreate(0, name, OBJ_BUTTON, 0, 0, 0);
      ObjectSetString(0, name, OBJPROP_TEXT, "X");
      ObjectSetInteger(0, name, OBJPROP_FONTSIZE, FontSize - 1);
      ObjectSetString(0, name, OBJPROP_FONT, FontFace);
      ObjectSetInteger(0, name, OBJPROP_COLOR, clrWhite);
      ObjectSetInteger(0, name, OBJPROP_BGCOLOR, C'200,60,60'); 
      ObjectSetInteger(0, name, OBJPROP_BORDER_COLOR, C'200,60,60');
      ObjectSetInteger(0, name, OBJPROP_STATE, false);
      ObjectSetInteger(0, name, OBJPROP_SELECTABLE, false);
      ObjectSetInteger(0, name, OBJPROP_ZORDER, 100); 
      ObjectSetInteger(0, name, OBJPROP_HIDDEN, true);
   }
   ObjectSetInteger(0, name, OBJPROP_CORNER, CORNER_LEFT_UPPER);
   ObjectSetInteger(0, name, OBJPROP_XDISTANCE, x);
   ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);
   ObjectSetInteger(0, name, OBJPROP_XSIZE, size);
   ObjectSetInteger(0, name, OBJPROP_YSIZE, size);
}

void SetEquityBox(double entryPrice)
{
   string bgN = PREFIX + "EQ_BG";
   string txN = PREFIX + "EQ_TX";

   if(!ShowEquityBox)
   {
      ObjectDelete(0, bgN); ObjectDelete(0, txN);
      return;
   }

   int px, py;
   if(!ChartTimePriceToXY(0, 0, iTime(_Symbol,_Period,0), entryPrice, px, py)) return;

   double equity = AccountInfoDouble(ACCOUNT_EQUITY);
   string eqStr  = "E: $" + DoubleToString(equity, 2);

   int cw  = (int)ChartGetInteger(0, CHART_WIDTH_IN_PIXELS);
   int ch  = (int)ChartGetInteger(0, CHART_HEIGHT_IN_PIXELS);

   int cw0 = (int)(Equity_FontSize * 0.72);
   int eqW = (int)(StringLen(eqStr) * cw0) + 20; 
   int eqH = Label_Height - 6;  
   int T   = Border_Thickness;

   int bx  = (cw - Label_FromRight) + (Label_Width / 2) - (eqW / 2);
   int by  = py + Label_Height / 2 + 6;  
   by = MathMax(T+1, MathMin(ch - eqH - T - 1, by));

   string outerN = bgN + "_OUT", innerN = bgN + "_IN";

   if(ObjectFind(0,outerN)<0) ObjectCreate(0,outerN,OBJ_RECTANGLE_LABEL,0,0,0);
   ObjectSetInteger(0,outerN,OBJPROP_CORNER,      CORNER_LEFT_UPPER);
   ObjectSetInteger(0,outerN,OBJPROP_XDISTANCE,   bx);
   ObjectSetInteger(0,outerN,OBJPROP_YDISTANCE,   by);
   ObjectSetInteger(0,outerN,OBJPROP_XSIZE,       eqW);
   ObjectSetInteger(0,outerN,OBJPROP_YSIZE,       eqH);
   ObjectSetInteger(0,outerN,OBJPROP_BGCOLOR,     Equity_Border);
   ObjectSetInteger(0,outerN,OBJPROP_BORDER_TYPE, BORDER_FLAT);

   if(ObjectFind(0,innerN)<0) ObjectCreate(0,innerN,OBJ_RECTANGLE_LABEL,0,0,0);
   ObjectSetInteger(0,innerN,OBJPROP_CORNER,      CORNER_LEFT_UPPER);
   ObjectSetInteger(0,innerN,OBJPROP_XDISTANCE,   bx+T);
   ObjectSetInteger(0,innerN,OBJPROP_YDISTANCE,   by+T);
   ObjectSetInteger(0,innerN,OBJPROP_XSIZE,       eqW-T*2);
   ObjectSetInteger(0,innerN,OBJPROP_YSIZE,       eqH-T*2);
   ObjectSetInteger(0,innerN,OBJPROP_BGCOLOR,     Equity_BG);
   ObjectSetInteger(0,innerN,OBJPROP_BORDER_TYPE, BORDER_FLAT);

   if(ObjectFind(0,txN)<0) ObjectCreate(0,txN,OBJ_LABEL,0,0,0);
   ObjectSetInteger(0,txN,OBJPROP_CORNER,    CORNER_LEFT_UPPER);
   ObjectSetInteger(0,txN,OBJPROP_XDISTANCE, bx + T + 6);
   ObjectSetInteger(0,txN,OBJPROP_YDISTANCE, by + eqH/2 - Equity_FontSize/2 - 1);
   ObjectSetInteger(0,txN,OBJPROP_FONTSIZE,  Equity_FontSize);
   ObjectSetString(0, txN,OBJPROP_FONT,      FontFace);
   ObjectSetInteger(0,txN,OBJPROP_COLOR,     Equity_TextColor);
   ObjectSetString(0, txN,OBJPROP_TEXT,      eqStr);
}

void SetLabel(string id,double price,string sideStr,string lotStr,
              string valStr,color sideCol,color valCol, string btnID="")
{
   int px,py;
   if(!ChartTimePriceToXY(0,0,iTime(_Symbol,_Period,0),price,px,py)) return;
   int cw=(int)ChartGetInteger(0,CHART_WIDTH_IN_PIXELS);
   int ch=(int)ChartGetInteger(0,CHART_HEIGHT_IN_PIXELS);
   int W=Label_Width,H=Label_Height,T=Border_Thickness;
   int bx=cw-Label_FromRight;
   int by=MathMax(T+1,MathMin(ch-H-T-1,py-H/2));
   int tY=by+H/2-FontSize/2-1;
   int cw0=(int)(FontSize*0.68);

   SetRect(PREFIX+"BX_"+id,bx,by,W,H,Label_BG,sideCol,T);

   int x1=bx+T+6;
   SetText(PREFIX+"SD_"+id,x1,tY,sideStr,sideCol);

   int x2=x1+(int)(StringLen(sideStr)*cw0)+4;
   SetText(PREFIX+"S1_"+id,x2,tY,"|",Sep_Color);

   int x3=x2+cw0+4;
   SetText(PREFIX+"LT_"+id,x3,tY,ShowLotSize?lotStr:"",Label_DimText);

   int lotW=ShowLotSize?(int)(StringLen(lotStr)*cw0)+4:0;
   int x4=x3+lotW;
   SetText(PREFIX+"S2_"+id,x4,tY,"|",Sep_Color);

   int x5=x4+cw0+4;
   SetText(PREFIX+"VL_"+id,x5,tY,valStr,valCol);

   if(btnID != "")
   {
      SetXButton(btnID, bx + W + 2, by, H); 
   }
}

double GetFrozenPPP(ulong ticket, ENUM_ORDER_TYPE ot,
                    double entry, double lot,
                    double livePrice, double liveProfit)
{
   string key   = PPP_KEY + IntegerToString((long)ticket);
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);

   if(GlobalVariableCheck(key))
   {
      double v = GlobalVariableGet(key);
      if(MathAbs(v) > 0) return v;
   }

   double ppp = 0;
   double testPrice  = (ot==ORDER_TYPE_BUY) ? entry+point : entry-point;
   double testProfit = 0;
   if(OrderCalcProfit(ot,_Symbol,lot,entry,testPrice,testProfit))
      if(MathAbs(testProfit) > 0)
         ppp = testProfit;

   if(ppp == 0)
   {
      double dist = (ot==ORDER_TYPE_BUY) ? (livePrice-entry) : (entry-livePrice);
      double minDist = point * MinPointsToLock;
      if(MathAbs(dist) >= minDist && MathAbs(liveProfit) > 0.0001)
         ppp = (liveProfit / dist) * point;
   }

   if(ppp == 0)
   {
      double tv = SymbolInfoDouble(_Symbol,SYMBOL_TRADE_TICK_VALUE);
      double ts = SymbolInfoDouble(_Symbol,SYMBOL_TRADE_TICK_SIZE);
      if(ts > 0 && tv > 0)
         ppp = (point/ts) * tv * lot;
   }

   if(MathAbs(ppp) > 0)
      GlobalVariableSet(key, ppp);

   return ppp;
}

double FixedMoney(double ppp, double entry, double target, ENUM_ORDER_TYPE ot)
{
   double point = SymbolInfoDouble(_Symbol,SYMBOL_POINT);
   double dist  = (target-entry)/point;
   if(ot==ORDER_TYPE_SELL) dist=-dist;
   return dist*ppp;
}

void CleanOldPPP()
{
   for(int i=GlobalVariablesTotal()-1;i>=0;i--)
   {
      string n=GlobalVariableName(i);
      if(StringFind(n,PPP_KEY)!=0) continue;
      ulong t=(ulong)StringToInteger(StringSubstr(n,StringLen(PPP_KEY)));
      if(!PositionSelectByTicket(t)) GlobalVariableDel(n);
   }
}

