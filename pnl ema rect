void BuildMaRows()
{
   int px=g_ox;
   int py=MA_RowsY();
   int totalH=MA_HDR_H+MA_COUNT*MA_ROW_H;
   
   MakeRectLabel(MA_PANEL_BG, px,py,MA_PANEL_W,totalH,CLR_PANEL_BG,CLR_BORDER,90);
   MakeRectLabel(MA_PANEL_HDR,px,py,MA_PANEL_W,MA_HDR_H,CLR_HEADER_BG,CLR_BORDER,95);
   MakeLabel(MA_LABEL_TEXT, px+10,py+7,"≡ MA",CLR_TEXT_DARK,9,101);

   // Place Rectangle Tool button perfectly in line with MA header text
   MakeButton(HDR_RECT_BTN, px+MA_PANEL_W-28, py+4, 20, 20, isDrawing?"⬛":"⬛", 
              isDrawing?CLR_BTN_ACTIVE:CLR_HEADER_BG, isDrawing?clrWhite:CLR_TEXT_DARK, 9, 102);
   ObjectSetInteger(0,HDR_RECT_BTN,OBJPROP_SELECTABLE,true);

   for(int i=0;i<MA_COUNT;i++)
   {
      int ry=py+MA_HDR_H+i*MA_ROW_H;
      MakeRectLabel("MA_Sep_"+IntegerToString(i),px,ry,MA_PANEL_W,1,CLR_BORDER,CLR_BORDER,96);
      MakeRectLabel("MA_Dot_"+IntegerToString(i),px+7,ry+10,8,8,ma_colors[i],ma_colors[i],101);
      MakeLabel("MA_Lbl_"+IntegerToString(i),px+20,ry+5,
                "EMA "+IntegerToString(ma_periods[i]),CLR_TEXT_DARK,9,101);
      MakeLabel("MA_Sub_"+IntegerToString(i),px+20,ry+16,
                "P:"+IntegerToString(ma_periods[i])+"  W:"+IntegerToString(ma_widths[i]),
                CLR_TEXT_SUB,7,101);
      MakeButton("MA_Eye_"+IntegerToString(i),px+MA_PANEL_W-28,ry+4,20,20,
                 ma_visible[i]?"👁":"◌",CLR_BTN_BG,CLR_TEXT_DARK,9,102);
      ObjectSetInteger(0,"MA_Eye_"+IntegerToString(i),OBJPROP_SELECTABLE,true);
   }
}

