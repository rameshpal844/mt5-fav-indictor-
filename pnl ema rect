//==================================================================
// ── OnTimer ───────────────────────────────────────────────────────
//==================================================================
void OnTimer()
{
   if(!g_autoPositioned)
   {
      ApplyAutoPos();
      if(g_autoPositioned){ g_rebuild=true; Draw(); ChartRedraw(0); return; }
   }
   UpdateDayBal(); Draw(); ChartRedraw(0);
}

//==================================================================
// ── OnChartEvent ─────────────────────────────────────────────────
//==================================================================
void OnChartEvent(const int id,const long &lp,const double &dp,const string &sp)
{
   int x=(int)lp, y=(int)dp;

   // ── COLOR MEMORY: Save color if user changes properties of zone ──
   if(id == CHARTEVENT_OBJECT_CHANGE)
   {
      if(StringFind(sp, "ZoneRect_") == 0)
      {
         g_currentZoneColor = (color)ObjectGetInteger(0, sp, OBJPROP_COLOR);
         GlobalVariableSet(GV_COLOR, (double)g_currentZoneColor);
      }
   }

   //----------------------------------------------------------------
   // ESC — cancel rectangle drawing
   //----------------------------------------------------------------
   if(id==CHARTEVENT_KEYDOWN && lp==27)
   {
      if(isDrawing)
      {
         if(clickStep==1) ObjectDelete(0,currentObjName);
         isDrawing=false; clickStep=0;
         if(ObjectFind(0,HDR_RECT_BTN)>=0)
         {
            ObjectSetInteger(0,HDR_RECT_BTN,OBJPROP_BGCOLOR,CLR_HEADER_BG);
            ObjectSetInteger(0,HDR_RECT_BTN,OBJPROP_COLOR,CLR_TEXT_DARK);
         }
         ChartRedraw(0);
      }
      return;
   }

   // H key shortcut — toggle PnL rows
   if(id==CHARTEVENT_KEYDOWN && lp==72)
   {
      g_col=!g_col; g_rebuild=true;
      Draw(); ChartRedraw(0); return;
   }

   //----------------------------------------------------------------
   // OBJECT CLICK
   //----------------------------------------------------------------
   if(id==CHARTEVENT_OBJECT_CLICK)
   {
      // ── Main Header MA Panel toggle ──────────────
      if(sp==HDR_MA_BTN)
      {
         ma_panelExpanded=!ma_panelExpanded;
         ObjectSetInteger(0,HDR_MA_BTN,OBJPROP_STATE, false);
         ObjectSetString(0,HDR_MA_BTN,OBJPROP_TEXT, ma_panelExpanded?"MA▲":"MA▼");
         g_rebuild=true; Draw(); ChartRedraw(0); return;
      }

      // ── Rectangle tool inside MA panel ───────────
      if(sp==HDR_RECT_BTN)
      {
         isDrawing=!isDrawing; clickStep=0;
         ObjectSetInteger(0,HDR_RECT_BTN,OBJPROP_STATE, false);
         ObjectSetInteger(0,HDR_RECT_BTN,OBJPROP_BGCOLOR, isDrawing?CLR_BTN_ACTIVE:CLR_HEADER_BG);
         ObjectSetInteger(0,HDR_RECT_BTN,OBJPROP_COLOR, isDrawing?clrWhite:CLR_TEXT_DARK);
         ChartRedraw(0); return;
      }

      // ── Eye buttons (MA visibility toggles) ─────────────────────
      for(int i=0;i<MA_COUNT;i++)
      {
         string eye="MA_Eye_"+IntegerToString(i);
         if(sp==eye)
         {
            ma_visible[i]=!ma_visible[i];
            string gvName=GV_VIS_PREFIX+IntegerToString(i);
            GlobalVariableSet(gvName,ma_visible[i]?1.0:0.0);
            ObjectSetString (0,eye,OBJPROP_TEXT, ma_visible[i]?"👁":"◌");
            ObjectSetInteger(0,eye,OBJPROP_STATE,false);
            RedrawSingleMA(i);
            ChartRedraw(0); return;
         }
      }
   }

   //----------------------------------------------------------------
   // MOUSE MOVE — drag panel + live rectangle preview
   //----------------------------------------------------------------
   if(id==CHARTEVENT_MOUSE_MOVE)
   {
      bool held=(StringFind(sp,"1")>=0);
      int mx=x, my=y;

      if(!held)
      {
         if(g_drag)
         {
            g_drag=false;
            g_wasManuallyDragged=true; // Flag it as manually dragged!
            GlobalVariableSet(GV_X,g_ox);
            GlobalVariableSet(GV_Y,g_oy);
            g_rebuild=true; Draw(); ChartRedraw(0);
         }
         else if(g_mouseOnHdr)
         {
            // Short click on header LEFT side → toggle PnL rows
            int dx=MathAbs(mx-g_clickX), dy=MathAbs(my-g_clickY);
            bool onMABtn=(g_clickX>=g_ox+PW-35 && g_clickX<=g_ox+PW);
            if(dx<6 && dy<6 && !onMABtn)
            {
               g_col=!g_col; g_rebuild=true;
               Draw(); ChartRedraw(0);
            }
         }
         g_mouseOnHdr=false;
         return;
      }

      // Mouse held
      bool onHdr=(mx>=g_ox && mx<=g_ox+PW && my>=HdrY() && my<=HdrY()+HDR_H);

      if(!g_drag && !g_mouseOnHdr && onHdr)
      {
         g_mouseOnHdr=true; g_clickX=mx; g_clickY=my;
         g_dDX=mx-g_ox; g_dDY=my-HdrY();
      }

      if(g_mouseOnHdr && !g_drag)
      {
         if(MathAbs(mx-g_clickX)>4 || MathAbs(my-g_clickY)>4)
            g_drag=true;
      }

      if(g_drag)
      {
         int cw=(int)ChartGetInteger(0,CHART_WIDTH_IN_PIXELS);
         int ch=(int)ChartGetInteger(0,CHART_HEIGHT_IN_PIXELS);
         g_ox=MathMax(0,MathMin(mx-g_dDX,cw-PW));
         
         // Dynamically restrict drag based on expanded content height
         int ny = my-g_dDY;
         int topOffset = g_oy - PnlTopY();
         int botOffset = PnlBotY() - g_oy;
         if(ma_panelExpanded) {
            topOffset = MathMax(topOffset, g_oy - MA_RowsY());
            botOffset = MathMax(botOffset, (MA_RowsY() + MA_TotalH()) - g_oy);
         }
         ny = MathMax(topOffset, MathMin(ny, ch - botOffset));
         
         g_oy=ny;
         Reposition();
         ChartRedraw(0);
      }

      // Live rectangle preview while drawing - Zone moves Y axis only, extending infinitely to future
      if(isDrawing && clickStep==1)
      {
         datetime t; double p; int w;
         if(ChartXYToTimePrice(0,x,y,w,t,p))
         {
            ObjectSetDouble (0,currentObjName,OBJPROP_PRICE,1,p); // Adjust height only
            // Keep X axis fixed far into the future to create an infinite zone effect
            datetime futureTime = TimeCurrent() + 86400 * 365 * 10;
            ObjectSetInteger(0,currentObjName,OBJPROP_TIME,1,futureTime); 
            ChartRedraw(0);
         }
      }
      return;
   }

   //----------------------------------------------------------------
   // CHART CHANGE (scroll / zoom / resize)
   //----------------------------------------------------------------
   if(id==CHARTEVENT_CHART_CHANGE)
   {
      if(!g_autoPositioned){ ApplyAutoPos(); Draw(); ChartRedraw(0); return; }
      Reposition(); ChartRedraw(0);
   }

   //----------------------------------------------------------------
   // CHART CLICK — draw true shape zone (infinite rectangle)
   //----------------------------------------------------------------
   if(id==CHARTEVENT_CLICK && isDrawing && !g_drag)
   {
      if(GetTickCount()-lastClickTime<200) return;
      lastClickTime=GetTickCount();

      // Block clicks inside full panel boundary area
      int panelTop=PnlTopY();
      int panelBot=PnlBotY();
      if(ma_panelExpanded) {
         panelTop = (int)MathMin(panelTop, MA_RowsY());
         panelBot = (int)MathMax(panelBot, MA_RowsY() + MA_TotalH());
      }
      if(x>=g_ox && x<=g_ox+PW && y>=panelTop && y<=panelBot) return;

      datetime t; double p; int w;
      if(ChartXYToTimePrice(0,x,y,w,t,p))
      {
         if(clickStep==0)
         {
            startX=x; startY=y; startPrice=p; startTime=t;
            currentObjName="ZoneRect_"+IntegerToString(GetTickCount());
            
            // Push the 2nd time coordinate 10 years into the future automatically
            datetime futureTime = TimeCurrent() + 86400 * 365 * 10; 
            
            ObjectCreate(0,currentObjName,OBJ_RECTANGLE,0,startTime,startPrice,futureTime,startPrice);
            ObjectSetInteger(0,currentObjName,OBJPROP_COLOR,      g_currentZoneColor); 
            ObjectSetInteger(0,currentObjName,OBJPROP_FILL,       true);   
            ObjectSetInteger(0,currentObjName,OBJPROP_BACK,       true);
            ObjectSetInteger(0,currentObjName,OBJPROP_SELECTABLE, true);
            ObjectSetInteger(0,currentObjName,OBJPROP_SELECTED,   true);
            ObjectSetInteger(0,currentObjName,OBJPROP_HIDDEN,     false);
            
            // This ensures it displays on all timeframes regardless of where it is drawn
            ObjectSetInteger(0,currentObjName,OBJPROP_TIMEFRAMES, OBJ_ALL_PERIODS);
            
            clickStep=1;
         }
         else if(clickStep==1)
         {
            // Finish drawing
            if(MathAbs(x-startX)<5 && MathAbs(y-startY)<5) return;
            
            datetime futureTime = TimeCurrent() + 86400 * 365 * 10;
            ObjectSetInteger(0,currentObjName,OBJPROP_TIME,1,futureTime); // Lock to infinity
            ObjectSetDouble (0,currentObjName,OBJPROP_PRICE,1,p);         // Set final Y height
            ObjectSetInteger(0,currentObjName,OBJPROP_SELECTED,true); 
            
            isDrawing=false; clickStep=0;
            if(ObjectFind(0,HDR_RECT_BTN)>=0)
            {
               ObjectSetInteger(0,HDR_RECT_BTN,OBJPROP_BGCOLOR,CLR_HEADER_BG);
               ObjectSetInteger(0,HDR_RECT_BTN,OBJPROP_COLOR,CLR_TEXT_DARK);
            }
         }
         ChartRedraw(0);
      }
   }
}
