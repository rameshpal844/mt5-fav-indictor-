void DeleteMASegments(int m)
{
   string pfx=ma_linePrefix+IntegerToString(m)+"_";
   for(int j=ObjectsTotal(0)-1;j>=0;j--)
   {
      string nm=ObjectName(0,j);
      if(StringFind(nm,pfx)==0) ObjectDelete(0,nm);
   }
}

void DrawMALines(const int rates_total,const int prev_calculated,const datetime &time[])
{
   if(rates_total<2) return;
   int drawBars=MathMin(rates_total,500);
   ArraySetAsSeries(time,true);
   int limit=drawBars;
   if(prev_calculated==rates_total) limit=2;

   for(int m=0;m<MA_COUNT;m++)
   {
      if(!ma_visible[m]) continue;
      if(ma_handles[m]==INVALID_HANDLE) continue;
      double buf[]; ArraySetAsSeries(buf,true);
      if(CopyBuffer(ma_handles[m],0,0,limit+1,buf)<=0) continue;
      for(int i=1;i<limit;i++)
      {
         double p1=buf[i],p2=buf[i-1];
         if(p1==0||p2==0) continue;
         string seg=ma_linePrefix+IntegerToString(m)+"_"+IntegerToString(i);
         datetime t1=time[i],t2=time[i-1];
         if(ObjectFind(0,seg)<0)
         {
            ObjectCreate(0,seg,OBJ_TREND,0,t1,p1,t2,p2);
            ObjectSetInteger(0,seg,OBJPROP_COLOR,      ma_colors[m]);
            ObjectSetInteger(0,seg,OBJPROP_STYLE,      STYLE_SOLID);
            ObjectSetInteger(0,seg,OBJPROP_WIDTH,      ma_widths[m]);
            ObjectSetInteger(0,seg,OBJPROP_RAY_RIGHT,  false);
            ObjectSetInteger(0,seg,OBJPROP_BACK,       true);
            ObjectSetInteger(0,seg,OBJPROP_SELECTABLE, false);
            ObjectSetInteger(0,seg,OBJPROP_HIDDEN,     true);
            ObjectSetInteger(0,seg,OBJPROP_TIMEFRAMES, OBJ_ALL_PERIODS);
         }
         else
         {
            ObjectSetInteger(0,seg,OBJPROP_TIME,0,t1); ObjectSetDouble(0,seg,OBJPROP_PRICE,0,p1);
            ObjectSetInteger(0,seg,OBJPROP_TIME,1,t2); ObjectSetDouble(0,seg,OBJPROP_PRICE,1,p2);
         }
      }
   }
}

void RedrawSingleMA(int m)
{
   DeleteMASegments(m);
   if(!ma_visible[m]) return;
   if(ma_handles[m]==INVALID_HANDLE) return;
   int rates_total=(int)ChartGetInteger(0,CHART_VISIBLE_BARS)+500;
   datetime times[]; ArraySetAsSeries(times,true);
   int copied=CopyTime(_Symbol,PERIOD_CURRENT,0,rates_total,times);
   if(copied<=0) return;
   int drawBars=MathMin(copied,500);
   double buf[]; ArraySetAsSeries(buf,true);
   if(CopyBuffer(ma_handles[m],0,0,drawBars,buf)<=0) return;
   for(int i=1;i<drawBars-1;i++)
   {
      double p1=buf[i],p2=buf[i-1];
      if(p1==0||p2==0) continue;
      string seg=ma_linePrefix+IntegerToString(m)+"_"+IntegerToString(i);
      datetime t1=times[i],t2=times[i-1];
      ObjectCreate(0,seg,OBJ_TREND,0,t1,p1,t2,p2);
      ObjectSetInteger(0,seg,OBJPROP_COLOR,      ma_colors[m]);
      ObjectSetInteger(0,seg,OBJPROP_STYLE,      STYLE_SOLID);
      ObjectSetInteger(0,seg,OBJPROP_WIDTH,      ma_widths[m]);
      ObjectSetInteger(0,seg,OBJPROP_RAY_RIGHT,  false);
      ObjectSetInteger(0,seg,OBJPROP_BACK,       true);
      ObjectSetInteger(0,seg,OBJPROP_SELECTABLE, false);
      ObjectSetInteger(0,seg,OBJPROP_HIDDEN,     true);
      ObjectSetInteger(0,seg,OBJPROP_TIMEFRAMES, OBJ_ALL_PERIODS);
   }
}

//==================================================================
// ── OnInit ────────────────────────────────────────────────────────
//==================================================================
int OnInit()
{
   ChartSetInteger(0,CHART_EVENT_OBJECT_CREATE,true);
   ChartSetInteger(0,CHART_EVENT_OBJECT_DELETE,true);
   ChartSetInteger(0,CHART_EVENT_MOUSE_MOVE,   true);

   // Check if user completely changed the Default Snap Setting in Inputs 
   int savedSetting = -1;
   if(GlobalVariableCheck(GV_SET)) {
      savedSetting = (int)GlobalVariableGet(GV_SET);
   }

   // Restore Position if the user previously dragged it manually (and didn't just change settings)
   if(savedSetting == (int)InpDefaultPos && GlobalVariableCheck(GV_X) && GlobalVariableCheck(GV_Y))
   {
      g_ox = (int)GlobalVariableGet(GV_X);
      g_oy = (int)GlobalVariableGet(GV_Y);
      g_autoPositioned = true;     // Prevent snap because user dragged it manually before
      g_wasManuallyDragged = true; // Mark as dragged so it keeps saving
   }
   else
   {
      // No saved position OR the user just changed the Default Corner dropdown setting
      g_autoPositioned = false;     // Let ApplyAutoPos() snap it automatically
      g_wasManuallyDragged = false; // It's not a manual drag right now
   }
   
   // Remember the current dropdown setting for next time
   GlobalVariableSet(GV_SET, (int)InpDefaultPos);

   // RESTORE SAVED COLOR
   if(GlobalVariableCheck(GV_COLOR)) {
       g_currentZoneColor = (color)GlobalVariableGet(GV_COLOR);
   }

   // MA setup — restore visibility
   ma_periods[0]=MA1_Period; ma_colors[0]=MA1_Color; ma_widths[0]=MA1_Width; ma_visible[0]=true;
   ma_periods[1]=MA2_Period; ma_colors[1]=MA2_Color; ma_widths[1]=MA2_Width; ma_visible[1]=true;
   ma_periods[2]=MA3_Period; ma_colors[2]=MA3_Color; ma_widths[2]=MA3_Width; ma_visible[2]=true;
   ma_periods[3]=MA4_Period; ma_colors[3]=MA4_Color; ma_widths[3]=MA4_Width; ma_visible[3]=true;

   for(int i=0;i<MA_COUNT;i++)
   {
      string gvName=GV_VIS_PREFIX+IntegerToString(i);
      if(GlobalVariableCheck(gvName))
         ma_visible[i]=(GlobalVariableGet(gvName)>0.0);
   }

   for(int i=0;i<MA_COUNT;i++)
   {
      ma_handles[i]=iMA(_Symbol,PERIOD_CURRENT,ma_periods[i],0,MODE_EMA,PRICE_CLOSE);
      if(ma_handles[i]==INVALID_HANDLE) Print("MA handle ",i," failed");
   }

   g_col=true;
   g_rebuild=true;
   UpdateDayBal(); Draw(); EventSetTimer(1);
   ChartRedraw(0);
   return INIT_SUCCEEDED;
}

//==================================================================
// ── OnDeinit ──────────────────────────────────────────────────────
//==================================================================
void OnDeinit(const int reason)
{
   EventKillTimer();
   ChartSetInteger(0,CHART_EVENT_MOUSE_MOVE,false);

   // Only save exact X/Y position if it was MANUALLY dragged by the user.
   if(g_wasManuallyDragged)
   {
      GlobalVariableSet(GV_X, g_ox);
      GlobalVariableSet(GV_Y, g_oy);
   }
   else
   {
      // If it's just sitting in the default corner, delete old saves so it can naturally snap on restart
      if(GlobalVariableCheck(GV_X)) GlobalVariableDel(GV_X);
      if(GlobalVariableCheck(GV_Y)) GlobalVariableDel(GV_Y);
   }

   // Save MA visibility
   for(int i=0;i<MA_COUNT;i++)
   {
      string gvName=GV_VIS_PREFIX+IntegerToString(i);
      GlobalVariableSet(gvName, ma_visible[i]?1.0:0.0);
   }

   ObjectsDeleteAll(0,g_pfx);
   DestroyMaRows();
   ObjectDelete(0,HDR_MA_BTN);
   for(int i=0;i<MA_COUNT;i++)
   {
      if(ma_handles[i]!=INVALID_HANDLE) IndicatorRelease(ma_handles[i]);
      DeleteMASegments(i);
   }
   ChartRedraw(0);
}

//==================================================================
// ── OnCalculate ───────────────────────────────────────────────────
//==================================================================
int OnCalculate(const int rates_total,const int prev_calculated,
                const datetime &time[],const double &open[],
                const double &high[],const double &low[],const double &close[],
                const long &tick_volume[],const long &volume[],const int &spread[])
{
   DrawMALines(rates_total,prev_calculated,time);
