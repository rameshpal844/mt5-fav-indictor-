//==================================================================
// ── DAY / BALANCE LOGIC (PnL) ─────────────────────────────────────
//==================================================================
datetime DayStart()
{
   datetime now=TimeGMT(); MqlDateTime d; TimeToStruct(now,d);
   d.hour=InpResetHour_UTC; d.min=InpResetMin_UTC; d.sec=1;
   datetime r=StructToTime(d);
   return now<r ? r-86400 : r;
}
void UpdateDayBal()
{
   datetime ds=DayStart();
   if(ds==g_lastDay&&g_dayStartBal>0) return;
   double bal=AccountInfoDouble(ACCOUNT_BALANCE),net=0;
   HistorySelect(ds,TimeCurrent());
   for(int i=0;i<HistoryDealsTotal();i++)
   {
      ulong tk=HistoryDealGetTicket(i); if(!tk) continue;
      ENUM_DEAL_TYPE  dt=(ENUM_DEAL_TYPE) HistoryDealGetInteger(tk,DEAL_TYPE);
      ENUM_DEAL_ENTRY de=(ENUM_DEAL_ENTRY)HistoryDealGetInteger(tk,DEAL_ENTRY);
      if(dt!=DEAL_TYPE_BUY&&dt!=DEAL_TYPE_SELL) continue;
      if(de!=DEAL_ENTRY_OUT&&de!=DEAL_ENTRY_INOUT) continue;
      net+=HistoryDealGetDouble(tk,DEAL_PROFIT)
          +HistoryDealGetDouble(tk,DEAL_SWAP)
          +HistoryDealGetDouble(tk,DEAL_COMMISSION);
   }
   g_dayStartBal=bal-net; g_lastDay=ds;
}

//==================================================================
// ── AUTO POSITION (PnL) ───────────────────────────────────────────
//==================================================================
void ApplyAutoPos()
{
   int cw=(int)ChartGetInteger(0,CHART_WIDTH_IN_PIXELS);
   int ch=(int)ChartGetInteger(0,CHART_HEIGHT_IN_PIXELS);
   if(cw<=0||ch<=0) return;
   
   int bm=2, tm=6, sm=6;
   switch(InpDefaultPos)
   {
      case POS_LOWER_RIGHT: g_ox=cw-PW-sm;  g_oy=ch-HDR_H-bm; break;
      case POS_LOWER_LEFT:  g_ox=sm;        g_oy=ch-HDR_H-bm; break;
      case POS_UPPER_RIGHT: g_ox=cw-PW-sm;  g_oy=tm;          break;
      case POS_UPPER_LEFT:  g_ox=sm;        g_oy=tm;          break;
   }
   g_autoPositioned=true;
   g_rebuild=true;
}

//==================================================================
// ── COMPUTE BAR WIDTHS (PnL) ──────────────────────────────────────
//==================================================================
void CalcBar(int &lW,int &rW,int &ddFx,int &tgFx)
{
   double ddu=MathMax(0,InpStartingBalance-AccountInfoDouble(ACCOUNT_EQUITY));
   double ovn=AccountInfoDouble(ACCOUNT_BALANCE)-InpStartingBalance;
   double tot=InpMaxDD+InpOverallTarget;
   lW  =(int)MathRound(BAR_W*InpMaxDD/tot);
   rW  =BAR_W-lW;
   ddFx=InpMaxDD>0            ?(int)MathMin(ddu/InpMaxDD*lW,             (double)lW):0;
   tgFx=(InpOverallTarget>0&&ovn>0)?(int)MathMin(ovn/InpOverallTarget*rW,(double)rW):0;
}

//==================================================================
// ── MAIN DRAW (PnL + combined header) ────────────────────────────
//==================================================================
void Draw()
{
   // Compute PnL values
   datetime ds=DayStart();
   double dp2=0,dl=0;
   HistorySelect(ds,ds+86400);
   for(int i=0;i<HistoryDealsTotal();i++)
   {
      ulong tk=HistoryDealGetTicket(i); if(!tk) continue;
      ENUM_DEAL_TYPE  dt=(ENUM_DEAL_TYPE) HistoryDealGetInteger(tk,DEAL_TYPE);
      ENUM_DEAL_ENTRY de=(ENUM_DEAL_ENTRY)HistoryDealGetInteger(tk,DEAL_ENTRY);
      if(dt!=DEAL_TYPE_BUY&&dt!=DEAL_TYPE_SELL) continue;
      if(de!=DEAL_ENTRY_OUT&&de!=DEAL_ENTRY_INOUT) continue;
      double p=HistoryDealGetDouble(tk,DEAL_PROFIT)
              +HistoryDealGetDouble(tk,DEAL_SWAP)
              +HistoryDealGetDouble(tk,DEAL_COMMISSION);
      if(p>0) dp2+=p; else dl+=p;
   }
   for(int i=0;i<PositionsTotal();i++)
   {
      ulong ptk=PositionGetTicket(i); if(!ptk) continue;
      double p=PositionGetDouble(POSITION_PROFIT)+PositionGetDouble(POSITION_SWAP);
      if(p>0) dp2+=p; else dl+=p;
   }
   double dn  = dp2+dl;
   double bal = AccountInfoDouble(ACCOUNT_BALANCE);
   double eq  = AccountInfoDouble(ACCOUNT_EQUITY);
   double ovn = bal-InpStartingBalance;
   int lW,rW,ddFx,tgFx; CalcBar(lW,rW,ddFx,tgFx);
   double ddu = MathMax(0,InpStartingBalance-eq);
   double ddP = InpMaxDD>0 ? ddu/InpMaxDD*100.0 : 0;

   color ddC = ddP>=80?clrRed:ddP>=50?clrOrange:(color)C'200,40,40';
   color tgC = ovn>=InpOverallTarget?(color)C'0,200,0':ovn>0?(color)C'0,160,60':(color)C'160,200,160';
   color ovC = ovn<0?ddC:ovn>0?tgC:InpTextColor;
   color eqC = eq>=InpStartingBalance?(color)C'255,220,50':(color)C'255,140,80';
   color nvC = dn>=0?InpNetPosColor:InpNetNegColor;

   string eqS = InpCurrency+DoubleToString(eq,2);
   string pvS = (dp2>=0?"+":"")+InpCurrency+DoubleToString(dp2,2);
   string lvS = "-"+InpCurrency+DoubleToString(MathAbs(dl),2);
   string nvS = (dn>=0?"+":"")+InpCurrency+DoubleToString(dn,2);
   string ovS = (ovn>=0?"+":"")+InpCurrency+DoubleToString(ovn,2);
   string ddH = "MaxDD "+InpCurrency+DoubleToString(InpMaxDD,0);
   string tgH = "Target "+InpCurrency+DoubleToString(InpOverallTarget,0);

   // ── FULL REBUILD ─────────────────────────────────────────────
   if(g_rebuild)
   {
      ObjectsDeleteAll(0,g_pfx);
      DestroyMaRows();
      ObjectDelete(0,HDR_MA_BTN);
      g_rebuild=false;

      int hY=HdrY(), cY=ContentY();
      
      // Dynamic boundary checks for Outer BG
      int topY = PnlTopY();
      int botY = PnlBotY();
      if(ma_panelExpanded) {
         topY = (int)MathMin(topY, MA_RowsY());
         botY = (int)MathMax(botY, MA_RowsY() + MA_TotalH());
      }
      int combinedH = botY - topY;

      R(g_pfx+"BG", g_ox, topY, PW, combinedH, InpBgColor, InpBorderColor, 1);
      R(g_pfx+"HD", g_ox, hY, PW, HDR_H, InpHdrBg, InpHdrBg, 0);
      L(g_pfx+"TT", g_ox+8,  hY+8, "= EQ", InpHdrText, 8);
      L(g_pfx+"EQ", g_ox+50, hY+5, eqS, eqC, InpEqFontSize, ANCHOR_LEFT_UPPER);

      // MA Toggle Button inside Main Header (Smaller, lighter blue, size 7)
      B(HDR_MA_BTN, g_ox+PW-34, hY+7, 26, 16, ma_panelExpanded?"MA▲":"MA▼", (color)C'40,55,120', clrWhite, 7);
      ObjectSetInteger(0,HDR_MA_BTN,OBJPROP_SELECTABLE,true);
      ObjectSetInteger(0,HDR_MA_BTN,OBJPROP_HIDDEN,false);

      if(!g_col)
      {
         L(g_pfx+"PL", g_ox+8,    cY+4,  "Profit",  InpTextColor,   9);
         L(g_pfx+"PV", g_ox+PW-6, cY+2,  pvS, InpProfitColor, 11, ANCHOR_RIGHT_UPPER);
         R(g_pfx+"S1", g_ox,      cY+17, PW,1, InpSepColor,InpSepColor,0);
         L(g_pfx+"LL", g_ox+8,    cY+22, "Loss",    InpTextColor,   9);
         L(g_pfx+"LV", g_ox+PW-6, cY+20, lvS, InpLossColor,   11, ANCHOR_RIGHT_UPPER);
         R(g_pfx+"S2", g_ox,      cY+35, PW,1, InpSepColor,InpSepColor,0);
         R(g_pfx+"NB", g_ox,      cY+36, PW,20,(color)C'235,240,255',(color)C'235,240,255',0);
         L(g_pfx+"NL", g_ox+8,    cY+42, "Net PnL", InpTextColor,   9);
         L(g_pfx+"NV", g_ox+PW-6, cY+38, nvS, nvC, 13, ANCHOR_RIGHT_UPPER);
         R(g_pfx+"S3", g_ox,      cY+56, PW,1, InpSepColor,InpSepColor,0);
         int bsY=cY+57, barY=bsY+14;
         R(g_pfx+"BS",  g_ox, bsY, PW,46,(color)C'244,247,255',(color)C'244,247,255',0);
         L(g_pfx+"BHL", g_ox+BAR_X,    bsY+2, ddH, (color)C'170,40,40',7);
         L(g_pfx+"BHR", g_ox+PW-BAR_X, bsY+2, tgH, (color)C'30,130,30',7,ANCHOR_RIGHT_UPPER);
         L(g_pfx+"OVL", g_ox+PW/2,     bsY+2, "overall",(color)C'140,150,195',6,ANCHOR_UPPER);
         R(g_pfx+"BLB", g_ox+BAR_X,              barY, lW,            BAR_H,(color)C'255,222,222',(color)C'200,155,155',1);
         R(g_pfx+"BRB", g_ox+BAR_X+lW,           barY, rW,            BAR_H,(color)C'222,255,222',(color)C'155,200,155',1);
         R(g_pfx+"DDF", g_ox+BAR_X+lW-MathMax(ddFx,1),barY,MathMax(ddFx,1),BAR_H,ddC,ddC,0);
         R(g_pfx+"TGF", g_ox+BAR_X+lW,           barY, MathMax(tgFx,1),BAR_H,tgC,tgC,0);
         R(g_pfx+"CDV", g_ox+BAR_X+lW-1,         barY, 2,BAR_H,InpTextColor,InpTextColor,0);
         L(g_pfx+"OV",  g_ox+PW/2,               barY+BAR_H+2,ovS,ovC,12,ANCHOR_UPPER);
      }

      if(ma_panelExpanded) BuildMaRows();
      return;
   }

   // ── VALUE-ONLY UPDATE (timer — zero blink) ────────────────────
   ObjectSetString (0,g_pfx+"EQ", OBJPROP_TEXT,  eqS);
   ObjectSetInteger(0,g_pfx+"EQ", OBJPROP_COLOR, eqC);
   if(g_col) return;

   ObjectSetString (0,g_pfx+"PV", OBJPROP_TEXT,  pvS);
   ObjectSetString (0,g_pfx+"LV", OBJPROP_TEXT,  lvS);
   ObjectSetString (0,g_pfx+"NV", OBJPROP_TEXT,  nvS);
   ObjectSetInteger(0,g_pfx+"NV", OBJPROP_COLOR, nvC);

   int cY=ContentY(), bsY=cY+57, barY=bsY+14;
   ObjectSetInteger(0,g_pfx+"DDF",OBJPROP_XDISTANCE,g_ox+BAR_X+lW-MathMax(ddFx,1));
   ObjectSetInteger(0,g_pfx+"DDF",OBJPROP_XSIZE,    MathMax(ddFx,1));
   ObjectSetInteger(0,g_pfx+"DDF",OBJPROP_BGCOLOR,  ddC);
   ObjectSetInteger(0,g_pfx+"TGF",OBJPROP_XDISTANCE,g_ox+BAR_X+lW);
   ObjectSetInteger(0,g_pfx+"TGF",OBJPROP_XSIZE,    MathMax(tgFx,1));
   ObjectSetInteger(0,g_pfx+"TGF",OBJPROP_BGCOLOR,  tgC);
   ObjectSetString (0,g_pfx+"OV", OBJPROP_TEXT,  ovS);
   ObjectSetInteger(0,g_pfx+"OV", OBJPROP_COLOR, ovC);
}

