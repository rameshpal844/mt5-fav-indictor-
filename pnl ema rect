      int ry=py+MA_HDR_H+i*MA_ROW_H;
      ObjMove("MA_Sep_"+IntegerToString(i),px,ry);
      ObjMove("MA_Dot_"+IntegerToString(i),px+7,ry+10);
      ObjMove("MA_Lbl_"+IntegerToString(i),px+20,ry+5);
      ObjMove("MA_Sub_"+IntegerToString(i),px+20,ry+16);
